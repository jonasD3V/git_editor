{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/electron",
    "rootDir": ".",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "bundler"
  },
  "include": ["src/**/*", "electron/**/*"],
  "exclude": ["node_modules", "dist"],
  "references": [{ "path": "../core" }, { "path": "../ui" }]
}
